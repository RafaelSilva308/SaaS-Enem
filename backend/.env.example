# ─── App ─────────────────────────────────────────────────────────────
APP_ENV=development           # development | staging | production
SECRET_KEY=change-me-in-production-use-min-32-random-chars
FRONTEND_URL=http://localhost:3000

# ─── Database (Neon PostgreSQL) ───────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@host/dbname
DATABASE_URL_SYNC=postgresql://user:password@host/dbname

# ─── Redis ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Auth / JWT ───────────────────────────────────────────────────────
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30
JWT_ALGORITHM=HS256

# ─── Email (Resend) ───────────────────────────────────────────────────
RESEND_API_KEY=re_your_key_here
EMAIL_FROM=noreply@saas-enem.com.br

# ─── AI ───────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key          # Fallback: GPT-4o para correção de redação
GOOGLE_API_KEY=your-gemini-key             # Primário: Gemini 1.5 Flash

# ─── Payments (Stripe) ────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...              # sk_live_... em produção
STRIPE_WEBHOOK_SECRET=whsec_...            # stripe listen --forward-to localhost:8000/api/v1/subscriptions/webhook
STRIPE_PRICE_ID_1M=price_...              # ID do Price no Stripe para plano mensal  (R$59,90)
STRIPE_PRICE_ID_3M=price_...              # ID do Price no Stripe para plano trimestral (R$99,90)
STRIPE_PRICE_ID_6M=price_...              # ID do Price no Stripe para plano semestral (R$149,90)

# ─── Storage (Cloudflare R2) ──────────────────────────────────────────
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
R2_BUCKET_NAME=saas-enem-assets

# ─── Web Push (VAPID) ─────────────────────────────────────────────────
# Gerar com: python -m py_vapid --gen-key (requer pip install py-vapid)
VAPID_PUBLIC_KEY=                          # Chave pública VAPID (Base64url)
VAPID_PRIVATE_KEY=                         # Chave privada VAPID (Base64url)
VAPID_CLAIMS_EMAIL=mailto:admin@saas-enem.com.br

# ─── Produção — checklist ─────────────────────────────────────────────
# [ ] APP_ENV=production
# [ ] SECRET_KEY=<64+ random chars>
# [ ] FRONTEND_URL=https://seu-dominio.com.br  (sem barra final)
# [ ] DATABASE_URL=<neon production connection string>
# [ ] REDIS_URL=<railway redis URL>
# [ ] STRIPE_SECRET_KEY=sk_live_...
# [ ] VAPID keys gerados e configurados
# [ ] docs_url e redoc_url já desabilitados automaticamente em production
